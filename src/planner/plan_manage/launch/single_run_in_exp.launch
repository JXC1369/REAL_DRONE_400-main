<launch>
    <!-- 预测动态障碍物数量（仅影响动态障碍预测模块，静态避障不依赖此值） -->
    <arg name="obj_num" value="10" />
    <!-- 多机编队时的无人机编号，单机一般保持 0 -->
    <arg name="drone_id" value="0"/>

    <!-- 局部地图尺寸（单位：米），建议覆盖飞行区域并留安全余量 -->
    <arg name="map_size_x" value="20"/>
    <arg name="map_size_y" value="20"/>
    <arg name="map_size_z" value="1.5"/>
    <!-- 里程计话题：当前工程默认使用 FAST-LIO 输出的高频里程计 -->
    <!-- <arg name="odom_topic" value="/vins_fusion/imu_propagate"/> -->
    <arg name="odom_topic" value="/Odom_high_freq"/>
    
    <!-- 主算法参数入口：将本文件参数传给 advanced_param_exp.xml -->
    <include file="$(find ego_planner)/launch/advanced_param_exp.xml">
        <arg name="drone_id" value="$(arg drone_id)"/>
        <arg name="map_size_x_" value="$(arg map_size_x)"/>
        <arg name="map_size_y_" value="$(arg map_size_y)"/>
        <arg name="map_size_z_" value="$(arg map_size_z)"/>
        <arg name="odometry_topic" value="$(arg odom_topic)"/>
        <arg name="obj_num_set" value="$(arg obj_num)" />
        <!-- 深度相机模式参数（使用激光点云时可忽略） -->
        <!-- camera_pose_topic: 相机位姿话题（世界系） -->
        <!-- depth_topic: 深度图话题（默认 640x480） -->
        <!-- 注意：若使用 cloud_topic，请不要同时依赖 depth/camera_pose 输入 -->
        <arg name="camera_pose_topic" value="nouse1"/>
        <arg name="depth_topic" value="/camera/depth/image_rect_raw"/>
        <!-- 点云输入话题（推荐激光雷达场景使用） -->
        <!-- FAST-LIO 默认输出 /cloud_registered -->
        <arg name="cloud_topic" value="/cloud_registered"/>
        <!-- 相机内参（仅深度图建图时有效） -->
        <arg name="cx" value="323.3316345214844"/>
        <arg name="cy" value="234.95498657226562"/>
        <arg name="fx" value="384.39654541015625"/>
        <arg name="fy" value="384.39654541015625"/>
        <!-- 规划速度上限（请与控制器能力匹配，过大可能导致跟踪困难） -->
        <arg name="max_vel" value="0.8" />
        <arg name="max_acc" value="0.5" />
        <!-- 规划前瞻距离，通常建议 ≈ 感知半径的 1.5 倍 -->
        <arg name="planning_horizon" value="6" />
        <!-- 多机差异化轨迹开关：单机可保持 false -->
        <arg name="use_distinctive_trajs" value="false" />
        <!-- 飞行模式：1=RViz 2D Nav Goal 指点飞；2=按下方航点自动飞 -->
        <arg name="flight_type" value="1" />
        <!-- 全局航点（flight_type=2 时生效） -->
        <!-- 轨迹会在这些航点间生成分段轨迹 -->
        <arg name="point_num" value="2" />
        <arg name="point0_x" value="3.0" />
        <arg name="point0_y" value="0.0" />
        <arg name="point0_z" value="0.4" />
        <arg name="point1_x" value="3.0" />
        <arg name="point1_y" value="-1.0" />
        <arg name="point1_z" value="0.4" />
        <arg name="point2_x" value="3.18" />
        <arg name="point2_y" value="1.45" />
        <arg name="point2_z" value="0.6" />
        <arg name="point3_x" value="0.37" />
        <arg name="point3_y" value="1.75" />
        <arg name="point3_z" value="0.6" />
        <arg name="point4_x" value="0.37" />
        <arg name="point4_y" value="1.75" />
        <arg name="point4_z" value="0.6" />
    </include>
    <!-- 轨迹发布节点：向控制器发送规划后的 B-spline 轨迹 -->
    <node pkg="ego_planner" name="drone_$(arg drone_id)_traj_server" type="traj_server" output="screen">
        <!-- 如需适配其他控制接口，可在此处修改 remap -->
        <!-- <remap from="position_cmd" to="/setpoints_cmd"/> -->
        <remap from="~planning/bspline" to="drone_$(arg drone_id)_planning/bspline"/>
        <!-- 轨迹前瞻时间（秒），适度增大可提升跟踪平滑性 -->
        <param name="traj_server/time_forward" value="1.0" type="double"/>
    </node>
</launch>
